# ================================================================
# Hermes Agent - Environment Variables (.env)
# ================================================================
# Copy this file to ~/.hermes/.env and fill in your real values.
# NEVER commit ~/.hermes/.env to version control!
#
# Generated from hermes-agent-config migration package.
# ================================================================

# --- API Keys ---

# DeepSeek API Key (primary provider)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# DashScope / Alibaba Cloud API Key (Qwen, vision models)
# Get yours at: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY

# Zhipu AI / GLM API Key
# Get yours at: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=YOUR_ZHIPU_API_KEY

# --- Optional Providers ---

# Qwen / Alibaba Cloud (alternative endpoint)
# QWEN_API_KEY=YOUR_QWEN_API_KEY

# OpenAI (optional, for auxiliary services)
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Anthropic (optional)
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# --- Platform Credentials ---

# WeChat iLink Bot Token (for WeChat messaging)
# Format: "account@im.bot:secret"
ILINK_BOT_TOKEN=YOUR_ILINK_BOT_TOKEN

# Yuanbao / WeCom Home Channel
YUANBAO_HOME_CHANNEL=YOUR_YUANBAO_HOME_CHANNEL_TOKEN

# --- GitHub ---

# GitHub Personal Access Token (for private repo access, API calls)
# Get yours at: https://github.com/settings/tokens
# Store this in ~/.git-credentials instead of here:
#   https://YOUR_GITHUB_USERNAME:YOUR_GITHUB_PAT@github.com
GITHUB_PAT=YOUR_GITHUB_PAT

# --- Networking (for servers in China) ---

# Xray / V2Ray SOCKS5 proxy (if behind firewall)
# HTTP_PROXY=http://127.0.0.1:10809
# HTTPS_PROXY=http://127.0.0.1:10809
# ALL_PROXY=socks5://127.0.0.1:10808

# --- Optional: Bitwarden Secrets ---
# BWS_ACCESS_TOKEN=YOUR_BITWARDEN_ACCESS_TOKEN

# --- Optional: TTS / Voice ---
# ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
# XAI_API_KEY=YOUR_XAI_API_KEY
